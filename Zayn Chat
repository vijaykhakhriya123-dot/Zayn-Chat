AddCommand("serverhop", {"sh", "hop"}, "Switches servers (min/max players)", {{"min", "max"}}, function(Caller, Args)
    if (Caller == LocalPlayer) then
        Utils.Notify(LocalPlayer, "ZAYN HUB", "Looking for best servers...");
        
        local order = "Desc"
        local Option = string.lower(Args[1] or "max")
        
        if Option == "min" then
            order = "Asc"
        end

        local Server;
        local url = string.format("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=%s&limit=100", game.PlaceId, order)
        local starting = tick()
        
        repeat
            local success, result = pcall(function()
                return game:HttpGet(url)
            end)
            
            if (not success) then
                task.wait(2)
                continue
            end
            
            local decoded = Services.HttpService:JSONDecode(result)
            if (decoded and decoded.data and #decoded.data ~= 0) then
                for _, v in pairs(decoded.data) do
                    if (v.maxPlayers and v.playing and v.maxPlayers > v.playing and v.id ~= game.JobId) then
                        Server = v
                        break
                    end
                end
            end
            
            if (Server) then break end
            
            if decoded.nextPageCursor then
                url = string.format("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=%s&limit=100&cursor=%s", game.PlaceId, order, decoded.nextPageCursor)
            else
                break
            end
        until tick() - starting >= 10 -- Timeout shortened for efficiency

        if (not Server) then
            return "Bhai, koi sahi server nahi mila!"
        end

        -- Zayn Hub Persistent Loading (Teleport ke baad bhi load hoga)
        local queue_on_teleport = syn and syn.queue_on_teleport or queue_on_teleport
        if (queue_on_teleport) then
            -- Yahan aapka apna Zayn Hub loadstring aayega
            queue_on_teleport([[
                repeat task.wait() until game:IsLoaded()
                print("Zayn Hub Re-Loaded on erennn0779's command!")
            ]])
        end

        Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, Server.id)    
        return string.format("Joining server (%d/%d players)... Chalo Zayn bhai!", Server.playing, Server.maxPlayers)
    end
end)
