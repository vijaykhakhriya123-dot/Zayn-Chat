        if (_L.Frame2 and Enabled) then
            -- Disconnect logic
            if PredictionConnection then PredictionConnection:Disconnect() end
            if PredictLabel then PredictLabel:Destroy() end
            _L.Frame2 = nil
            Enabled = false
            return
        end

        -- Roblox Standard Chat Bar find karna
        local RobloxChat = LocalPlayer.PlayerGui:FindFirstChild("Chat")
        local ChatBar;
        
        if RobloxChat then
            local BoxFrame = RobloxChat:FindFirstChild("BoxFrame", true)
            if BoxFrame then
                _L.Frame2 = BoxFrame:FindFirstChild("Frame")
                if _L.Frame2 then
                    local SourceLabel = _L.Frame2:FindFirstChild("TextLabel")
                    ChatBar = _L.Frame2:FindFirstChild("ChatBar")
                    
                    if SourceLabel and ChatBar then
                        -- Prediction Label Create karna (Ghost Text style)
                        PredictLabel = Instance.new("TextLabel")
                        PredictLabel.Name = "ZaynPredict"
                        PredictLabel.Size = UDim2.new(1, 0, 1, 0)
                        PredictLabel.BackgroundTransparency = 1
                        PredictLabel.TextTransparency = 0.4 -- Ghost effect
                        PredictLabel.TextColor3 = SourceLabel.TextColor3
                        PredictLabel.Font = SourceLabel.Font
                        PredictLabel.TextSize = SourceLabel.TextSize
                        PredictLabel.TextXAlignment = SourceLabel.TextXAlignment
                        PredictLabel.Text = ""
                        PredictLabel.Parent = _L.Frame2
                    end
                end
            end
        end

        if not ChatBar then return end

        -- Prediction Logic
        PredictionConnection = ChatBar:GetPropertyChangedSignal("Text"):Connect(function()
            local RawText = ChatBar.Text
            PredictLabel.Text = ""

            -- Agar text prefix se start nahi ho raha toh ignore karo
            if not RawText:match("^" .. Prefix) then return end

            local Args = RawText:split(" ")
            local CommandPart = Args[1]:sub(#Prefix + 1) -- Remove prefix for matching

            -- Command/Alias Matcher
            for _, cmd in next, CommandsTable do
                if Utils.MatchSearch(CommandPart, cmd.Name) then
                    PredictLabel.Text = Prefix .. cmd.Name
                    CommandArgs = cmd.Args or {}
                    break
                end
                for _, alias in next, cmd.Aliases do
                    if Utils.MatchSearch(CommandPart, alias) then
                        PredictLabel.Text = Prefix .. alias
                        CommandArgs = cmd.Args or {}
                        break
                    end
                end
            end

            -- Player Argument Matching (Space ke baad)
            if #Args > 1 then
                local CurrentArg = Args[#Args]
                if CurrentArg ~= "" then
                    local PlayerMatch = Utils.GetPlayerArgs(CurrentArg)
                    if PlayerMatch then
                        local BaseText = RawText:sub(1, #RawText - #CurrentArg)
                        PredictLabel.Text = BaseText .. PlayerMatch
                    end
                end
            end

            -- Tab Completion Bypass (Standard Roblox Chat)
            if RawText:find("\t") then
                ChatBar.Text = PredictLabel.Text:gsub("\t", "")
                ChatBar.CursorPosition = #ChatBar.Text + 1
            end
        end)

        Enabled = true
        Utils.Notify("ZAYN HUB", "Master, Chat Prediction ab active hai!")
        return ChatBar
    end
