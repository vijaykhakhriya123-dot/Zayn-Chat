-- Zayn Hub Advanced Player Finder
local GetPlayer;
GetPlayer = function(str, noerror)
    local CurrentPlayers = filter(GetPlayers(Players), function(i, v)
        return not Tfind(Exceptions, v);
    end)
    
    if (not str) then return {} end
    str = lower(trim(str));
    
    -- Multi-target support (e.g. !kill me,others)
    if (Sfind(str, ",")) then
        return flatMap(split(str, ","), function(i, v)
            return GetPlayer(v, noerror);
        end)
    end

    local Magnitudes = map(CurrentPlayers, function(i, v)
        local Root = GetRoot(v)
        return {v, Root and (Root.CFrame.p - GetRoot().CFrame.p).Magnitude or math.huge}
    end)

    -- Zayn Target Arguments
    local PlayerArgs = {
        ["all"] = function()
            return filter(CurrentPlayers, function(i, v) return v ~= LocalPlayer end)
        end,
        ["others"] = function()
            return filter(CurrentPlayers, function(i, v) return v ~= LocalPlayer end)
        end,
        ["nearest"] = function()
            sort(Magnitudes, function(a, b) return a[2] < b[2] end)
            return {Magnitudes[2] and Magnitudes[2][1] or nil}
        end,
        ["farthest"] = function()
            sort(Magnitudes, function(a, b) return a[2] > b[2] end)
            return {Magnitudes[#Magnitudes] and Magnitudes[#Magnitudes][1] or nil}
        end,
        ["random"] = function()
            return {#CurrentPlayers > 1 and {CurrentPlayers[random(2, #CurrentPlayers)]} or {}}
        end,
        ["me"] = function() return {LocalPlayer} end,
        ["npcs"] = function()
            local NPCs = {}
            local Descendants = GetDescendants(Workspace);
            for i = 1, #Descendants do
                local D = Descendants[i]
                if (IsA(D, "Humanoid") and IsA(D.Parent, "Model") and Players:GetPlayerFromCharacter(D.Parent) == nil) then
                    local FakePlr = InstanceNew("Player");
                    FakePlr.Character = D.Parent
                    FakePlr.Name = D.Parent.Name
                    NPCs[#NPCs + 1] = FakePlr
                end
            end
            return NPCs
        end
    }

    if (PlayerArgs[str]) then return PlayerArgs[str](); end

    -- Name and DisplayName matching
    local Matched = filter(CurrentPlayers, function(i, v)
        return (sub(lower(v.Name), 1, #str) == str) or (sub(lower(v.DisplayName), 1, #str) == str);
    end)

    if (not next(Matched) and not noerror) then
        -- Updated Notification Credit
        Utils.Notify(LocalPlayer, "ZAYN HUB", "Player not found: " .. str);
    end
    return Matched
end

