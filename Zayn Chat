-- Zayn Core: Command Registration Function
local AddCommand = function(name, aliases, description, options, func, isplugin)
    local Cmd = {
        Name = name,
        Aliases = aliases,
        Description = description,
        Options = options,
        Function = function()
            -- Validation Logic
            for i, v in next, options do
                if (type(v) == 'function' and v() == false) then
                    Utils.Warn("Requirements not met for this command.", LocalPlayer)
                    return nil
                elseif (type(v) == 'number' and CommandRequirements[v]) then
                    if (CommandRequirements[v].Func() == false) then
                        Utils.Warn(CommandRequirements[v].Message, LocalPlayer)
                        return nil
                    end
                end
            end
            return func
        end,
        -- Parsing Arguments needed
        ArgsNeeded = tonumber(filter(options, function(i,v) return type(v) == "string" end)[1]) or 0,
        Args = filter(options, function(i, v) return type(v) == "table" end)[1] or {},
        CmdEnv = {},
        IsPlugin = isplugin == true
    }

    CommandsTable[name] = Cmd
    if (type(aliases) == 'table') then
        for _, v in next, aliases do
            CommandsTable[v] = Cmd
        end
    end
    return true
end
