-- Advanced Argument Parser (e.g., !kill near -> !kill nearest)
Utils.GetPlayerArgs = function(Arg)
    Arg = lower(Arg);
    local SpecialCases = {"all", "others", "random", "me", "nearest", "farthest", "npcs", "allies", "enemies"}
    
    local FoundSpecial = Utils.StringFind(SpecialCases, Arg)
    if (FoundSpecial) then return FoundSpecial end

    local CurrentPlayers = GetPlayers(Players);
    for i, v in next, CurrentPlayers do
        local Name, DisplayName = lower(v.Name), lower(v.DisplayName)
        if (Name ~= DisplayName and Utils.MatchSearch(Arg, DisplayName)) then
            return DisplayName;
        end
        if (Utils.MatchSearch(Arg, Name)) then
            return Name;
        end
    end
end
