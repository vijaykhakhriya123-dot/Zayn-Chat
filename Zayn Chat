    local Char = GetCharacter()
    local RightArm = FindFirstChild(Char, "RightLowerArm") or FindFirstChild(Char, "Right Arm")
    if not RightArm then return end
    
    local ArmPos = RightArm.CFrame * CFrame.new(0, -1, 0, 1, 0, 0, 0, 0, 1, 0, -1, 0)
    tool.Grip = Inverse(toObjectSpace(ArmPos, pos))
end

-- Zayn Cleaner: Disconnects connections of a specific command
local DisableAllCmdConnections = function(Cmd)
    local Command = LoadCommand(Cmd)
    if (Command and Command.CmdEnv) then
        for _, v in next, flat(Command.CmdEnv) do
            if (type(v) == 'userdata' and v.Disconnect) then
                Disconnect(v)
            end
        end
    end
    return Command
end
