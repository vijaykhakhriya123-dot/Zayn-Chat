-- Zayn High-Aura Rainbow Text (RichText Optimized)
Utils.Rainbow = function(TextObject)
    local Text = TextObject.Text
    local Frequency = 2 -- Adjust for speed
    local TotalCharacters = 0
    local Strings = {}

    TextObject.RichText = true

    for Character in gmatch(Text, ".") do
        if match(Character, "%s") then
            Strings[#Strings + 1] = Character
        else
            TotalCharacters = TotalCharacters + 1
            Strings[#Strings + 1] = {'<font color="rgb(%i, %i, %i)">' .. Character .. '</font>'}
        end
    end

    local Connection = AddConnection(CConnect(Heartbeat, function()
        local FinalString = ""
        local Counter = TotalCharacters

        for _, CharacterTable in ipairs(Strings) do
            local Char = CharacterTable
            if (type(CharacterTable) == "table") then
                Counter = Counter - 1
                -- Zayn Rainbow Math
                local Color = Color3.fromHSV((tick() * Frequency + (Counter / TotalCharacters)) % 1, 0.8, 1)
                Char = format(CharacterTable[1], floor(Color.R * 255), floor(Color.G * 255), floor(Color.B * 255))
            end
            FinalString = FinalString .. Char
        end
        TextObject.Text = FinalString
    end));

    -- Auto-disconnect after 150s to prevent lag in long sessions
    delay(150, function()
        if Connection then Disconnect(Connection) end
    end)
end

