-- Smooth Scrolling Logic (Elttob Method Integrated)
Utils.SmoothScroll = function(content, SmoothingFactor)
    -- Disable original scrolling to apply Zayn Smooth Logic
    content.ScrollingEnabled = false

    -- Create invisible input frame to capture mouse wheel/touch
    local input = Clone(content)
    input:ClearAllChildren();
    input.BackgroundTransparency = 1
    input.ScrollBarImageTransparency = 1
    input.ZIndex = content.ZIndex + 1
    input.Name = "_ZaynSmoothInput"
    input.ScrollingEnabled = true
    input.Parent = content.Parent

    -- Keep input frame in sync with Zayn Hub's content frame
    local function syncProperty(prop)
        AddConnection(CConnect(content:GetPropertyChangedSignal(prop), function()
            if prop == "ZIndex" then
                input[prop] = content[prop] + 1
            else
                input[prop] = content[prop]
            end
        end));
    end

    local properties = {
        "CanvasSize", "Position", "Rotation", "ScrollingDirection", 
        "ScrollBarThickness", "BorderSizePixel", "ElasticBehavior", 
        "SizeConstraint", "ZIndex", "BorderColor3", "Size", 
        "AnchorPoint", "Visible"
    }

    for _, prop in next, properties do syncProperty(prop) end

    -- Interpolation logic for buttery smooth scrolling
    local smoothConnection = AddConnection(CConnect(RenderStepped, function()
        local a = content.CanvasPosition
        local b = input.CanvasPosition
        local c = SmoothingFactor or 0.1 -- Default Zayn smoothing
        local d = (b - a) * c + a

        content.CanvasPosition = d
    end));

    -- Cleanup when Zayn Hub UI is closed/destroyed
    AddConnection(CConnect(content.AncestryChanged, function()
        if content.Parent == nil then
            input:Destroy();
            smoothConnection:Disconnect();
        end
    end));
end

-- Tween all UI elements to a specific transparency (Fade In/Out)
Utils.TweenAllTransToObject = function(Object, Time, BeforeObject)
    local Descendants = GetDescendants(Object);
    local OldDescentants = GetDescendants(BeforeObject);
    local Tween

    Tween = Utils.Tween(Object, "Sine", "Out", Time, {
        BackgroundTransparency = BeforeObject.BackgroundTransparency
    })

    for i = 1, #Descendants do
        local v = Descendants[i]
        local Target = OldDescentants[i]
        if not Target then continue end

        if (IsA(v, "GuiObject")) then
            local Goals = { BackgroundTransparency = Target.BackgroundTransparency }
            
            if (IsA(v, "TextLabel") or IsA(v, "TextButton") or IsA(v, "TextBox")) then
                Goals.TextTransparency = Target.TextTransparency
                Goals.TextStrokeTransparency = Target.TextStrokeTransparency
            elseif (IsA(v, "ImageLabel") or IsA(v, "ImageButton")) then
                Goals.ImageTransparency = Target.ImageTransparency
            elseif (IsA(v, "ScrollingFrame")) then
                Goals.ScrollBarImageTransparency = Target.ScrollBarImageTransparency
            end
            
            Utils.Tween(v, "Sine", "Out", Time, Goals)
        end
    end

    return Tween
end

