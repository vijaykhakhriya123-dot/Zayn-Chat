            Log.Parent = List
            Utils.Tween(Log, "Sine", "Out", .25, {TextTransparency = 0})
            List.CanvasSize = UDim2.fromOffset(0, List.UIListLayout.AbsoluteContentSize.Y)
        end
    end

    -- Hooking syn.request / request
    local RawRequest;
    RawRequest = hookfunction(syn and syn.request or request, newcclosure(function(reqtbl)
        AddLog(syn and "syn.request" or "request", reqtbl.Url, HttpService:JSONEncode(reqtbl))
        return RawRequest(reqtbl)
    end))

    -- Hooking game.HttpGet
    local RawHttpGet;
    RawHttpGet = hookfunction(game.HttpGet, newcclosure(function(self, url)
        AddLog("HttpGet", url)
        return RawHttpGet(self, url)
    end))

    -- Hooking game.HttpPost
    local RawHttpPost;
    RawHttpPost = hookfunction(game.HttpPost, newcclosure(function(self, url)
        AddLog("HttpPost", url)
        return RawHttpPost(self, url)
    end))

    return "Zayn HttpSpy Loaded!"
end)

