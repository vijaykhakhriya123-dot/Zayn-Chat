local Keys = {}

do
    local UserInputService = Services.UserInputService
    local WindowFocused = true
    
    AddConnection(CConnect(UserInputService.WindowFocusReleased, function() WindowFocused = false end))
    AddConnection(CConnect(UserInputService.WindowFocused, function() WindowFocused = true end))

    AddConnection(CConnect(UserInputService.InputBegan, function(Input, GameProcessed)
        -- Keyboard Focus Check
        Keys["GameProcessed"] = GameProcessed and WindowFocused and (UserInputService:GetFocusedTextBox() ~= nil)
        Keys["LastEntered"] = Input.KeyCode
        
        if (GameProcessed) then return end
        
        local KeyCodeStr = split(tostring(Input.KeyCode), ".")[3]
        Keys[KeyCodeStr] = true

        -- Zayn Macro Execution
        for i = 1, #Macros do
            local Macro = Macros[i]
            if (Tfind(Macro.Keys, Input.KeyCode)) then
                if (#Macro.Keys == 2) then
                    if (UserInputService:IsKeyDown(Macro.Keys[1]) and UserInputService:IsKeyDown(Macro.Keys[2])) then
                        ExecuteCommand(Macro.Command, Macro.Args, LocalPlayer)
                    end
                else
                    ExecuteCommand(Macro.Command, Macro.Args, LocalPlayer)
                end
            end
        end

        -- Zayn Console Toggle (F8)
        if (Input.KeyCode == Enum.KeyCode.F8) then
            if (Console.Visible) then
                local Tween = Utils.TweenAllTrans(Console, .25)
                CWait(Tween.Completed)
                Console.Visible = false
            else
                Console.Visible = true
                Utils.ClearAllObjects(Console.Frame.List)
                local Tween = Utils.TweenAllTransToObject(Console, .25, ConsoleTransparencyClone)
                
                -- Dynamic Console Scrolling Logic
                local ListLayout = Console.Frame.List:FindFirstChildOfClass("UIListLayout")
                if ListLayout then
                    AddConnection(CConnect(ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
                        local List = Console.Frame.List
                        if (List.CanvasSize.Y.Offset - List.AbsoluteSize.Y - List.CanvasPosition.Y < 20) then
                            task.wait()
                            List.CanvasPosition = Vector2.new(0, List.CanvasSize.Y.Offset + 500)
                        end
                    end))
                end
            end
        end
    end))

    AddConnection(CConnect(UserInputService.InputEnded, function(Input, GameProcessed)
        if (GameProcessed) then return end
        local KeyCodeStr = split(tostring(Input.KeyCode), ".")[3]
        if (Keys[KeyCodeStr]) then Keys[KeyCodeStr] = false end
    end))
end

