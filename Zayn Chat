-- [[ COMMAND BAR INTELLIGENCE (Auto-Correct & Prediction) ]] --
AddConnection(CConnect(CommandBar.Input:GetPropertyChangedSignal("Text"), function()
    local TextBox = CommandBar.Input
    local Prediction = TextBox.Predict
    local RawText = TextBox.Text
    local Args = RawText:split(" ")
    
    Prediction.Text = ""
    if RawText == "" then return end

    -- Command & Alias Prediction
    if not CommandsTable[Args[1]] then
        for _, cmd in next, CommandsTable do
            if Utils.MatchSearch(Args[1], cmd.Name) then
                Prediction.Text = cmd.Name
                CommandArgs = cmd.Args or {}
                break
            end
            for _, alias in next, cmd.Aliases do
                if Utils.MatchSearch(Args[1], alias) then
                    Prediction.Text = alias
                    CommandArgs = cmd.Args or {}
                    break
                end
            end
        end
    end

    -- Player & Argument Prediction (Space detect hone par)
    for i, arg in next, Args do
        if i > 1 and arg ~= "" then
            local PredictResult = ""
            -- Agar command ko "Player" argument chahiye toh Player list se match karo
            if CommandArgs[i-1] and CommandArgs[i-1]:lower() == "player" then
                PredictResult = Utils.GetPlayerArgs(arg) or PredictResult
            else
                -- Normal argument prediction
                PredictResult = Utils.GetPlayerArgs(arg) or PredictResult
            end
            
            -- Prediction text ko build karna
            local BaseText = RawText:sub(1, #RawText - #Args[#Args])
            Prediction.Text = BaseText .. PredictResult
        end
    end

    -- TAB Completion Bypass
    if RawText:find("\t") then
        TextBox.Text = Prediction.Text:gsub("\t", "")
        TextBox.CursorPosition = #TextBox.Text + 1
    end
end))
