    local AddLog = function(reqType, url, Req)
        if (getgenv().ZAYN_HUB and UI) then
            local Log = Clone(ChatLogMessage)
            local Timestamp = os.date("%X")
            Log.Text = string.format("%s Detected (%s)\nUrl: %s%s", 
