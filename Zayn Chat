-- Command: HttpSpy (Deep Hooking for erennn0779)
AddCommand("httplogs", {"httpspy", "hspy"}, "Enables Deep HTTP Monitoring", {}, function()
    local List = HttpLogs.Frame.List
    Utils.Notify("ZAYN HUB", "HttpSpy Loading... Master Zayn is now watching the traffic.")

