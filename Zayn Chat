-- Zayn Executor: The heart of command processing
local PluginConf = { SafePlugins = true }
local ExecuteCommand = function(Name, Args, Caller)
    local Command = LoadCommand(Name)
    if (Command) then
        -- Arg Check
        if (Command.ArgsNeeded > #Args) then
            return Utils.Warn(format("Bhai, %d arguments chahiye (aapne kam diye hain)", Command.ArgsNeeded), LocalPlayer)
        end

        local Context
        local set_id = syn and syn.set_thread_identity or setidentity
        local get_id = syn and syn.get_thread_identity or getidentity

        -- Safe Execution Context for Plugins
        if (Command.IsPlugin and set_id and get_id and PluginConf.SafePlugins) then
            Context = get_id()
            set_id(2)
        end

        local Success, Ret = xpcall(function()
            local Func = Command.Function()
            if (Func) then
                local Result = Func(Caller, Args, Command.CmdEnv)
                if (Result) then Utils.Notify(Caller, "Zayn Exec", Result) end
                
                -- History Tracking
                if (Command.Name ~= "lastcommand") then
                    if (#LastCommand >= 3) then shift(LastCommand) end
                    LastCommand[#LastCommand + 1] = {Command.Name, Args, Caller, Command.CmdEnv}
                end
            end
        end, function(Err)
            if (Debug) then
                Utils.Error(format("[ZAYN CMD ERROR]: %s | Trace: %s", Name, debug.traceback(Err)), Caller)
                Utils.Notify(Caller, "Error", "Command fail ho gayi, Console check karo!")
            end
        end)

        if (Command.IsPlugin and set_id and Context) then set_id(Context) end
    else
        Utils.Warn("Command '" .. Name .. "' nahi mili!", Caller)
    end
end

